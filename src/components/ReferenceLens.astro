---
import lensIndex from '../data/lens.generated.json';
import { postLensScopes } from '../data/lensScopeMap.js';

const { postSlug } = Astro.props;

const namedScopes = postLensScopes[postSlug] ?? [];
const activeScopes = [postSlug, ...namedScopes, 'global'];
const scopePriority = new Map(
  activeScopes.map((scope, index) => [scope, index]),
);
const activeScopeSet = new Set(activeScopes);

const activeEntries = lensIndex
  .filter((entry) => activeScopeSet.has(entry.scope))
  .sort((a, b) => {
    const ap = scopePriority.get(a.scope) ?? Number.MAX_SAFE_INTEGER;
    const bp = scopePriority.get(b.scope) ?? Number.MAX_SAFE_INTEGER;

    if (ap !== bp) return ap - bp;
    return a.id.localeCompare(b.id);
  });

const lensData = JSON.stringify(activeEntries).replace(/</g, '\\u003c');
const panelId = `reference-lens-${postSlug}`;
---

<div class="reference-lens" data-reference-lens>
  <button
    class="reference-lens-open"
    type="button"
    aria-label="Reference Lens 열기"
    aria-expanded="false"
    aria-controls={panelId}
    data-reference-lens-open
    hidden
  >
    Lens 열기
  </button>

  <aside
    id={panelId}
    class="reference-lens-panel"
    role="complementary"
    aria-label="Reference Lens"
    data-reference-lens-panel
    hidden
  >
    <button
      class="reference-lens-resize"
      type="button"
      aria-label="Reference Lens 너비 조절"
      data-reference-lens-resize
    ></button>

    <div class="reference-lens-header">
      <h2>Reference Lens</h2>
      <button
        class="reference-lens-close"
        type="button"
        aria-label="Reference Lens 닫기"
        data-reference-lens-close
      >
        닫기 ×
      </button>
    </div>

    <input
      class="reference-lens-input"
      type="search"
      aria-label="Reference Lens 검색"
      placeholder="표기·정의·정리 검색"
      autocomplete="off"
      data-reference-lens-input
    />

    <p class="reference-lens-empty" data-reference-lens-empty>
      예: G[X] · tree decomposition · Theorem 4.1
    </p>

    <div class="reference-lens-results" data-reference-lens-results></div>
  </aside>

  <script type="application/json" data-reference-lens-data set:html={lensData}></script>
  <script is:inline>
    (() => {
      const root = document.currentScript?.closest('[data-reference-lens]');
      const panel = root?.querySelector('[data-reference-lens-panel]');
      const openButton = root?.querySelector('[data-reference-lens-open]');
      if (!panel || !openButton) return;

      let shouldOpen = true;
      try {
        const stored = JSON.parse(localStorage.getItem('referenceLensState') || '{}');
        if (typeof stored?.isOpen === 'boolean') shouldOpen = stored.isOpen;

        const storedWidth = Number.parseFloat(
          String(stored?.width ?? localStorage.getItem('referenceLensWidth') ?? ''),
        );
        if (Number.isFinite(storedWidth)) {
          const width = Math.min(720, Math.max(320, storedWidth));
          document.documentElement.style.setProperty('--reference-lens-width', `${width}px`);
        }
      } catch {}

      panel.hidden = !shouldOpen;
      openButton.hidden = shouldOpen;
      openButton.setAttribute('aria-expanded', String(shouldOpen));
    })();
  </script>
  <script>
    import '../scripts/referenceLens.ts';
  </script>
</div>
