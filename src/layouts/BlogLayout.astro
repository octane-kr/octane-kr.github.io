---
import 'katex/dist/katex.min.css';
import '../styles/global.css';

const {
  title = '코끼리 뿌우',
  description = '',
} = Astro.props;

const siteTitle = '코끼리 뿌우';
const pageTitle = title === siteTitle ? siteTitle : `${title} - ${siteTitle}`;
const pathname = Astro.url.pathname;
const activeSection = pathname === '/posts' || pathname.startsWith('/posts/')
  ? 'posts'
  : ['/projects', '/projects/', '/codeforces-lab', '/codeforces-lab/', '/ucpc-scoreboard', '/ucpc-scoreboard/'].includes(pathname)
    ? 'projects'
    : pathname === '/cv' || pathname === '/cv/'
      ? 'cv'
      : pathname === '/'
        ? 'home'
        : '';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
  </head>

  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <a class="site-title" href="/">{siteTitle}</a>
        <nav class="site-nav" aria-label="주요 메뉴">
          <a href="/" aria-current={activeSection === 'home' ? 'page' : undefined}>Home</a>
          <a href="/posts/" aria-current={activeSection === 'posts' ? 'page' : undefined}>Posts</a>
          <a href="/projects/" aria-current={activeSection === 'projects' ? 'page' : undefined}>Projects</a>
          <a href="/cv/" aria-current={activeSection === 'cv' ? 'page' : undefined}>CV</a>
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <span>© 2026 Octane</span>
        <span aria-hidden="true">·</span>
        <a href="/licensing/">Licensing</a>
      </div>
    </footer>
  </body>
</html>
