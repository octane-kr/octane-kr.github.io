---
import BlogLayout from './BlogLayout.astro';
import PostInteractions from '../components/PostInteractions.astro';

const { frontmatter } = Astro.props;

const title = frontmatter.title ?? 'Untitled';
const description = frontmatter.description ?? '';
const category = frontmatter.category ?? 'PS';
const subcategory = frontmatter.subcategory ?? '';

const parseDate = (value, isDateOnly = false) => {
  if (!value) return null;

  if (isDateOnly) {
    const dateText =
      value instanceof Date ? value.toISOString().slice(0, 10) : String(value).slice(0, 10);
    const date = new Date(`${dateText}T00:00:00+09:00`);
    return Number.isNaN(date.valueOf()) ? null : date;
  }

  const date = value instanceof Date ? value : new Date(value);
  return Number.isNaN(date.valueOf()) ? null : date;
};

const publishedAt = parseDate(frontmatter.publishedAt ?? frontmatter.date, !frontmatter.publishedAt);
const updatedAt = parseDate(frontmatter.updatedAt);
const hasUpdatedAt =
  publishedAt !== null &&
  updatedAt !== null &&
  updatedAt.valueOf() !== publishedAt.valueOf();

const dateTimeFormatter = new Intl.DateTimeFormat('ko-KR', {
  timeZone: 'Asia/Seoul',
  year: 'numeric',
  month: 'numeric',
  day: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  hourCycle: 'h23',
});

const formatDate = (date) => {
  if (date === null) return '날짜 없음';

  return dateTimeFormatter.format(date);
};

const formatCategory = (category, subcategory) =>
  subcategory ? `${category} / ${subcategory}` : category;

const categoryHref = `/posts/?category=${encodeURIComponent(category)}`;
const subcategoryHref = subcategory
  ? `${categoryHref}&subcategory=${encodeURIComponent(subcategory)}`
  : '';

const pathnameParts = Astro.url.pathname.split('/').filter(Boolean);
const postSlug = pathnameParts[pathnameParts.length - 1] ?? '';
---

<BlogLayout title={title} description={description}>
  <article class="article">
    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta-row">
        <div class="article-meta">
          <span class="article-category-meta">
            <a href={categoryHref}>{category}</a>
            {
              subcategory && (
                <>
                  <span aria-hidden="true">/</span>
                  <a href={subcategoryHref}>{subcategory}</a>
                </>
              )
            }
          </span>
          <span>{formatDate(publishedAt)}</span>
          {hasUpdatedAt && <span>최근 수정 {formatDate(updatedAt)}</span>}
        </div>

        <PostInteractions postSlug={postSlug} placement="top" />
      </div>
      {description && <p>{description}</p>}
    </header>

    <div class="article-body">
      <slot />
    </div>

    <PostInteractions postSlug={postSlug} placement="bottom" showComments={true} />
  </article>
</BlogLayout>
