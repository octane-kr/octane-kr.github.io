---
import BlogLayout from './BlogLayout.astro';
import PostInteractions from '../components/PostInteractions.astro';

const { frontmatter } = Astro.props;

const title = frontmatter.title ?? 'Untitled';
const description = frontmatter.description ?? '';
const category = frontmatter.category ?? 'PS';
const subcategory = frontmatter.subcategory ?? '';

const formatDate = (value) => {
  const date = new Date(value);
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
};

const formatCategory = (category, subcategory) =>
  subcategory ? `${category} / ${subcategory}` : category;

const categoryHref = `/posts/?category=${encodeURIComponent(category)}`;
const subcategoryHref = subcategory
  ? `${categoryHref}&subcategory=${encodeURIComponent(subcategory)}`
  : '';

const pathnameParts = Astro.url.pathname.split('/').filter(Boolean);
const postSlug = pathnameParts[pathnameParts.length - 1] ?? '';
---

<BlogLayout title={title} description={description}>
  <article class="article">
    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta-row">
        <div class="article-meta">
          <span class="article-category-meta">
            <a href={categoryHref}>{category}</a>
            {
              subcategory && (
                <>
                  <span aria-hidden="true">/</span>
                  <a href={subcategoryHref}>{subcategory}</a>
                </>
              )
            }
          </span>
          <span>{formatDate(frontmatter.date)}</span>
        </div>

        <PostInteractions postSlug={postSlug} placement="top" />
      </div>
      {description && <p>{description}</p>}
    </header>

    <div class="article-body">
      <slot />
    </div>

    <PostInteractions postSlug={postSlug} placement="bottom" showComments={true} />
  </article>
</BlogLayout>
