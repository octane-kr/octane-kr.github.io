---
import BlogLayout from '../layouts/BlogLayout.astro';

const description =
  'Codeforces 공개 데이터를 이용해 안 친 셋, 레이팅 그래프, 추정 퍼포먼스, 맞대결 기록을 확인하는 도구.';
---

<BlogLayout title="Codeforces Lab" description={description}>
  <article class="cf-page">
    <header class="cf-heading">
      <h1>Codeforces Lab</h1>
      <p>
        Codeforces 공개 데이터로 여러 핸들의 기록을 비교하고, 아직 아무도 치지 않은 셋을
        찾고, 레이팅과 추정 퍼포먼스를 한 화면에서 봅니다.
      </p>
      <p>
        퍼포먼스는 공식 값이 아니라 공개 레이팅 변동 데이터와 Codeforces식 예측기를
        이용해 재구성한 추정치입니다.
      </p>
    </header>

    <section class="cf-tool" aria-label="Codeforces 분석 도구" data-cf-lab>
      <form class="cf-handle-form" data-handle-form>
        <label class="cf-field cf-handle-field">
          <span>핸들</span>
          <textarea
            data-handles
            rows="3"
            spellcheck="false"
            autocomplete="off"
            placeholder="tourist, Petr"
          ></textarea>
        </label>
        <div class="cf-form-actions">
          <button type="submit">기록 불러오기</button>
          <button type="button" data-clear-cache>캐시 비우기</button>
        </div>
      </form>

      <p class="cf-status" data-status>쉼표로 구분한 핸들을 입력하세요.</p>

      <section class="cf-section" aria-labelledby="cf-users-title">
        <div class="cf-section-head">
          <h2 id="cf-users-title">불러온 핸들</h2>
        </div>
        <div class="cf-user-list" data-user-list>
          <p class="cf-empty">아직 불러온 핸들이 없습니다.</p>
        </div>
      </section>

      <nav class="cf-tabs" aria-label="기능 선택" role="tablist">
        <button class="cf-tab is-active" type="button" role="tab" aria-selected="true" data-cf-tab="fresh">안 친 셋</button>
        <button class="cf-tab" type="button" role="tab" aria-selected="false" data-cf-tab="rating">레이팅 그래프</button>
        <button class="cf-tab" type="button" role="tab" aria-selected="false" data-cf-tab="performance">퍼포먼스</button>
        <button class="cf-tab" type="button" role="tab" aria-selected="false" data-cf-tab="head">맞대결</button>
      </nav>

      <section class="cf-section cf-tab-panel is-active" aria-labelledby="cf-fresh-title" data-cf-panel="fresh">
        <div class="cf-section-head">
          <div>
            <h2 id="cf-fresh-title">아무도 치지 않은 셋</h2>
            <p>
              불러온 핸들의 레이팅 기록과 최근 제출 기록에 등장하지 않는 finished contest를
              찾습니다.
            </p>
          </div>
          <button type="button" data-find-fresh>찾기</button>
        </div>

        <div class="cf-filter-grid">
          <fieldset class="cf-fieldset">
            <legend>공식 라운드</legend>
            <label><input type="checkbox" data-official-division value="div4" checked /> Div. 4</label>
            <label><input type="checkbox" data-official-division value="div3" checked /> Div. 3</label>
            <label><input type="checkbox" data-official-division value="div2" checked /> Div. 2</label>
            <label><input type="checkbox" data-official-division value="div1" checked /> Div. 1</label>
            <label><input type="checkbox" data-official-division value="div1+2" checked /> Div. 1 + Div. 2</label>
          </fieldset>

          <fieldset class="cf-fieldset">
            <legend>Gym</legend>
            <label><input type="checkbox" data-include-gym checked /> 공개 Gym contest 포함</label>
            <div class="cf-duration-fields">
              <label class="cf-field cf-small-field">
                <span>최소 시간</span>
                <input data-gym-min type="text" inputmode="numeric" placeholder="HH:MM" />
              </label>
              <label class="cf-field cf-small-field">
                <span>최대 시간</span>
                <input data-gym-max type="text" inputmode="numeric" placeholder="HH:MM" />
              </label>
            </div>
          </fieldset>

          <fieldset class="cf-fieldset">
            <legend>스캔</legend>
            <label class="cf-field cf-small-field">
              <span>검사 범위</span>
              <select data-scan-depth>
                <option value="standard" selected>보통</option>
                <option value="quick">빠르게</option>
                <option value="careful">꼼꼼히</option>
                <option value="complete">전체 제출</option>
              </select>
            </label>
            <label class="cf-field cf-small-field">
              <span>결과 수</span>
              <input data-fresh-limit type="number" min="5" max="200" value="40" />
            </label>
          </fieldset>
        </div>

        <div class="cf-table-wrap" data-fresh-results>
          <p class="cf-empty">핸들을 불러온 뒤 찾기를 누르세요.</p>
        </div>
      </section>

      <section class="cf-section cf-tab-panel" aria-labelledby="cf-rating-title" data-cf-panel="rating" hidden>
        <div class="cf-section-head">
          <h2 id="cf-rating-title">레이팅 그래프</h2>
          <div class="cf-inline-controls">
            <label class="cf-field cf-small-field">
              <span>시작일 선택</span>
              <input data-rating-start type="date" />
            </label>
            <label class="cf-field cf-small-field">
              <span>끝일 선택</span>
              <input data-rating-end type="date" />
            </label>
          </div>
        </div>
        <div class="cf-chart" data-rating-chart>
          <p class="cf-empty">핸들을 불러오면 레이팅 그래프가 표시됩니다.</p>
        </div>
        <div class="cf-table-wrap" data-rating-table></div>
      </section>

      <section class="cf-section cf-tab-panel" aria-labelledby="cf-performance-title" data-cf-panel="performance" hidden>
        <div class="cf-section-head">
          <div>
            <h2 id="cf-performance-title">추정 퍼포먼스</h2>
            <p>
              공식 레이팅 변동 참가자 목록과 초반 6회 보너스 보정을 이용해
              퍼포먼스를 추정합니다.
            </p>
          </div>
          <div class="cf-inline-controls">
            <label class="cf-field cf-small-field">
              <span>시작일 선택</span>
              <input data-performance-start type="date" />
            </label>
            <label class="cf-field cf-small-field">
              <span>끝일 선택</span>
              <input data-performance-end type="date" />
            </label>
            <button type="button" data-load-performance>추정치 불러오기</button>
          </div>
        </div>
        <div class="cf-chart" data-performance-chart>
          <p class="cf-empty">핸들을 불러온 뒤 추정치를 불러오세요.</p>
        </div>
        <div class="cf-performance-summary" data-performance-summary>
          <p class="cf-empty">기간을 비우면 전체 rated contest를 대상으로 합니다.</p>
        </div>
      </section>

      <section class="cf-section cf-tab-panel" aria-labelledby="cf-head-title" data-cf-panel="head" hidden>
        <div class="cf-section-head">
          <h2 id="cf-head-title">맞대결</h2>
        </div>
        <div data-head-to-head>
          <p class="cf-empty">정확히 두 핸들을 불러오면 함께 친 rated contest를 비교합니다.</p>
        </div>
      </section>
    </section>
  </article>

  <script is:inline src="/codeforces-lab/app.js"></script>
</BlogLayout>

<style is:global>
  .cf-page {
    --cf-work-width: min(1180px, calc(100vw - 40px));
    width: var(--cf-work-width);
    max-width: none;
    margin-left: calc(50% - var(--cf-work-width) / 2);
    margin-right: calc(50% - var(--cf-work-width) / 2);
  }

  .cf-heading {
    max-width: 820px;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }

  .cf-heading h1 {
    margin: 0 0 10px;
    font-size: 38px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .cf-heading p {
    margin: 8px 0 0;
    color: #4b5563;
  }

  .cf-tool {
    display: grid;
    gap: 26px;
    min-width: 0;
    margin-bottom: 52px;
  }

  .cf-handle-form,
  .cf-section,
  .cf-filter-grid {
    border-top: 1px solid var(--line);
  }

  .cf-handle-form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
    min-width: 0;
    padding-top: 18px;
  }

  .cf-field {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .cf-field > span,
  .cf-fieldset legend {
    color: var(--muted);
    font-size: 13px;
  }

  .cf-field input,
  .cf-field textarea,
  .cf-field select {
    width: 100%;
    min-width: 0;
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    padding: 4px 0 7px;
  }

  .cf-field textarea {
    resize: vertical;
    line-height: 1.55;
  }

  .cf-field input:focus,
  .cf-field textarea:focus,
  .cf-field select:focus {
    border-bottom-color: var(--text);
    outline: 0;
  }

  .cf-small-field {
    min-width: 120px;
  }

  .cf-form-actions,
  .cf-inline-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 18px;
    align-items: end;
  }

  .cf-tool button {
    border: 0;
    border-bottom: 1px solid transparent;
    border-radius: 0;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font: inherit;
    padding: 0 0 2px;
  }

  .cf-tool button:hover:not(:disabled) {
    border-bottom-color: currentColor;
  }

  .cf-tool button:focus-visible {
    outline: 1px solid var(--text);
    outline-offset: 3px;
  }

  .cf-tool button:disabled {
    color: var(--muted);
    cursor: wait;
    opacity: 0.6;
  }

  .cf-status {
    margin: -10px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  .cf-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    align-items: center;
    padding-bottom: 9px;
    border-bottom: 1px solid var(--line);
  }

  .cf-tab {
    color: var(--muted);
    white-space: nowrap;
  }

  .cf-tab.is-active {
    border-bottom-color: currentColor;
    color: var(--text);
    font-weight: 700;
  }

  .cf-tab-panel[hidden] {
    display: none;
  }

  .cf-section {
    display: grid;
    gap: 14px;
    min-width: 0;
    padding-top: 22px;
  }

  .cf-section-head {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    align-items: end;
    justify-content: space-between;
  }

  .cf-section-head h2 {
    margin: 0;
    font-size: 22px;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .cf-section-head p {
    max-width: 720px;
    margin: 5px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  .cf-user-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px 20px;
  }

  .cf-user {
    min-width: 0;
    padding-top: 10px;
    border-top: 1px solid var(--line);
  }

  .cf-user strong {
    display: block;
    overflow-wrap: anywhere;
  }

  .cf-user span,
  .cf-empty,
  .cf-note {
    color: var(--muted);
    font-size: 13px;
  }

  .cf-empty {
    margin: 0;
  }

  .cf-chart {
    position: relative;
    min-height: 260px;
    min-width: 0;
    max-width: 100%;
    border-top: 1px solid var(--text);
    border-bottom: 1px solid var(--line);
    overflow-x: auto;
    padding: 10px 0 8px;
  }

  .cf-chart-tooltip {
    position: absolute;
    z-index: 2;
    display: none;
    max-width: min(320px, calc(100% - 24px));
    border: 1px solid var(--text);
    background: var(--bg);
    color: var(--text);
    font-size: 12px;
    line-height: 1.45;
    pointer-events: none;
    padding: 8px 10px;
  }

  .cf-chart-tooltip.is-visible {
    display: block;
  }

  .cf-chart-tooltip strong {
    display: block;
    margin-bottom: 4px;
  }

  .cf-chart-tooltip span {
    display: block;
    color: var(--muted);
  }

  .cf-chart svg {
    display: block;
    min-width: 720px;
    width: 100%;
    height: auto;
  }

  .cf-chart-axis,
  .cf-chart-grid {
    stroke: var(--line);
    stroke-width: 1;
  }

  .cf-chart-label {
    fill: var(--muted);
    font-size: 12px;
  }

  .cf-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    margin-top: 10px;
    color: var(--muted);
    font-size: 13px;
  }

  .cf-legend span {
    display: inline-flex;
    gap: 6px;
    align-items: center;
  }

  .cf-legend i {
    display: inline-block;
    width: 18px;
    height: 2px;
  }

  .cf-performance-summary {
    min-width: 0;
    border-top: 1px solid var(--line);
    padding-top: 10px;
  }

  .cf-summary-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    margin: 0;
    color: var(--muted);
    font-size: 13px;
  }

  .cf-summary-list strong {
    color: var(--text);
  }

  .cf-table-wrap {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    overflow-x: auto;
  }

  .cf-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
    font-size: 13px;
    line-height: 1.4;
  }

  .cf-table th,
  .cf-table td {
    border-bottom: 1px solid var(--line);
    padding: 8px 9px;
    text-align: left;
    vertical-align: top;
  }

  .cf-table th {
    color: var(--muted);
    font-weight: 700;
    white-space: nowrap;
  }

  .cf-table td strong {
    overflow-wrap: anywhere;
  }

  .cf-num {
    text-align: right;
    white-space: nowrap;
  }

  .cf-filter-grid {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) minmax(260px, 1fr) minmax(180px, 0.7fr);
    gap: 18px 26px;
    min-width: 0;
    padding-top: 16px;
  }

  .cf-fieldset {
    display: grid;
    gap: 8px;
    min-width: 0;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .cf-fieldset label {
    display: flex;
    gap: 8px;
    align-items: baseline;
    color: #4b5563;
    font-size: 14px;
  }

  .cf-fieldset input[type="checkbox"] {
    accent-color: var(--text);
  }

  .cf-duration-fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .cf-summary-line {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    margin: 0;
    color: #4b5563;
  }

  .cf-summary-line strong {
    color: var(--text);
  }

  @media (max-width: 860px) {
    .cf-page {
      width: 100%;
      max-width: 100%;
      margin-right: 0;
      margin-left: 0;
    }

    .cf-heading h1 {
      font-size: 31px;
    }

    .cf-handle-form,
    .cf-filter-grid {
      grid-template-columns: 1fr;
    }

    .cf-form-actions,
    .cf-inline-controls {
      align-items: baseline;
    }
  }
</style>
