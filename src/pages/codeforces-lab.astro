---
import BlogLayout from '../layouts/BlogLayout.astro';

const description =
  'Codeforces 공개 데이터를 이용해 안 친 셋, 레이팅 그래프, 추정 퍼포먼스, 맞대결 기록을 확인하는 도구.';
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_KEY;
const codeforcesCacheConfig =
  supabaseUrl && supabaseKey
    ? {
        endpoint: `${supabaseUrl}/functions/v1/codeforces-cache`,
        derivedEndpoint: `${supabaseUrl}/functions/v1/codeforces-derived`,
        anonKey: supabaseKey,
      }
    : null;
---

<BlogLayout title="Codeforces Lab" description={description}>
  <article class="cf-page">
    <header class="cf-heading">
      <h1>Codeforces Lab</h1>
      <p>
        여러 핸들의 공개 기록을 비교하고, 아무도 치지 않은 셋과 추정 퍼포먼스를
        확인합니다.
      </p>
    </header>

    <section class="cf-tool" aria-label="Codeforces 분석 도구" data-cf-lab>
      <form class="cf-handle-form" data-handle-form>
        <label class="cf-field cf-handle-field">
          <span>핸들</span>
          <textarea
            data-handles
            rows="1"
            spellcheck="false"
            autocomplete="off"
            placeholder="tourist, Petr"
          ></textarea>
        </label>
        <div class="cf-form-actions">
          <button type="submit">불러오기</button>
        </div>
      </form>

      <p class="cf-status" data-status aria-live="polite" hidden></p>

      <section class="cf-section" aria-labelledby="cf-users-title" data-users-section hidden>
        <div class="cf-section-head">
          <h2 id="cf-users-title">불러온 핸들</h2>
        </div>
        <div class="cf-user-list" data-user-list>
          <p class="cf-empty"></p>
        </div>
      </section>

      <nav class="cf-tabs" aria-label="기능 선택" role="tablist">
        <button id="cf-tab-fresh" class="cf-tab is-active" type="button" role="tab" aria-selected="true" aria-controls="cf-panel-fresh" data-cf-tab="fresh">안 친 셋</button>
        <button id="cf-tab-rating" class="cf-tab" type="button" role="tab" aria-selected="false" aria-controls="cf-panel-rating" data-cf-tab="rating">레이팅 그래프</button>
        <button id="cf-tab-performance" class="cf-tab" type="button" role="tab" aria-selected="false" aria-controls="cf-panel-performance" data-cf-tab="performance">퍼포먼스</button>
        <button id="cf-tab-head" class="cf-tab" type="button" role="tab" aria-selected="false" aria-controls="cf-panel-head" data-cf-tab="head">맞대결</button>
      </nav>

      <section id="cf-panel-fresh" class="cf-section cf-tab-panel is-active" aria-labelledby="cf-tab-fresh" data-cf-panel="fresh">
        <div class="cf-section-head">
          <p class="cf-panel-intro">
            선택한 범위의 제출 기록에서 참가 흔적이 없는 종료 대회를 찾습니다.
          </p>
          <button type="button" data-find-fresh>대회 찾기</button>
        </div>

        <div class="cf-filter-grid">
          <fieldset class="cf-fieldset">
            <legend>대회 종류</legend>
            <label><input type="checkbox" data-official-division value="div4" checked /> Div. 4</label>
            <label><input type="checkbox" data-official-division value="div3" checked /> Div. 3</label>
            <label><input type="checkbox" data-official-division value="div2" checked /> Div. 2</label>
            <label><input type="checkbox" data-official-division value="div1" checked /> Div. 1</label>
            <label><input type="checkbox" data-official-division value="div1+2" checked /> Div. 1 + Div. 2</label>
            <label><input type="checkbox" data-include-gym checked /> 공개 Gym 포함</label>
          </fieldset>

          <fieldset class="cf-fieldset">
            <legend>Gym 길이</legend>
            <div class="cf-duration-fields">
              <label class="cf-field cf-small-field">
                <span>최소 시간</span>
                <input data-gym-min type="text" inputmode="numeric" placeholder="HH:MM" />
              </label>
              <label class="cf-field cf-small-field">
                <span>최대 시간</span>
                <input data-gym-max type="text" inputmode="numeric" placeholder="HH:MM" />
              </label>
            </div>
          </fieldset>

          <fieldset class="cf-fieldset">
            <legend>제출 기록</legend>
            <label class="cf-field cf-small-field">
              <span>범위</span>
              <select data-scan-depth>
                <option value="standard" selected>최근 20,000개</option>
                <option value="quick">최근 1,000개</option>
                <option value="careful">최근 100,000개</option>
                <option value="complete">전체</option>
              </select>
            </label>
            <label class="cf-field cf-small-field">
              <span>결과 수</span>
              <input data-fresh-limit type="number" min="5" max="200" value="40" />
            </label>
          </fieldset>
        </div>

        <div class="cf-table-wrap" data-fresh-results></div>
      </section>

      <section id="cf-panel-rating" class="cf-section cf-tab-panel" aria-labelledby="cf-tab-rating" data-cf-panel="rating" hidden>
        <div class="cf-section-head cf-section-head-controls-only">
          <div class="cf-inline-controls">
            <label class="cf-field cf-small-field">
              <span>시작일</span>
              <input data-rating-start type="date" />
            </label>
            <label class="cf-field cf-small-field">
              <span>종료일</span>
              <input data-rating-end type="date" />
            </label>
          </div>
        </div>
        <div class="cf-chart" data-rating-chart></div>
      </section>

      <section id="cf-panel-performance" class="cf-section cf-tab-panel" aria-labelledby="cf-tab-performance" data-cf-panel="performance" hidden>
        <div class="cf-section-head">
          <p class="cf-panel-intro">
            공개 레이팅 변동으로 역산한 추정치입니다. 기간을 비우면 전체 rated contest를 봅니다.
          </p>
          <div class="cf-inline-controls">
            <label class="cf-field cf-small-field">
              <span>시작일</span>
              <input data-performance-start type="date" />
            </label>
            <label class="cf-field cf-small-field">
              <span>종료일</span>
              <input data-performance-end type="date" />
            </label>
            <button type="button" data-load-performance>추정치 불러오기</button>
          </div>
        </div>
        <div class="cf-chart" data-performance-chart></div>
        <div class="cf-performance-summary" data-performance-summary></div>
      </section>

      <section id="cf-panel-head" class="cf-section cf-tab-panel" aria-labelledby="cf-tab-head" data-cf-panel="head" hidden>
        <div data-head-to-head>
          <p class="cf-empty">핸들 두 개를 불러오면 함께 친 rated contest를 비교합니다.</p>
        </div>
      </section>
    </section>
  </article>

  <script define:vars={{ codeforcesCacheConfig }}>
    window.CodeforcesLabCache = codeforcesCacheConfig;
  </script>
  <script is:inline src="/codeforces-lab/app.js"></script>
</BlogLayout>

<style is:global>
  .cf-page {
    --cf-work-width: min(1180px, calc(100vw - 40px));
    width: var(--cf-work-width);
    max-width: none;
    margin-left: calc(50% - var(--cf-work-width) / 2);
    margin-right: calc(50% - var(--cf-work-width) / 2);
  }

  .cf-heading {
    max-width: 820px;
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }

  .cf-heading h1 {
    margin: 0 0 10px;
    font-size: 38px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .cf-heading p {
    margin: 8px 0 0;
    color: #4b5563;
  }

  .cf-tool {
    display: grid;
    gap: 26px;
    min-width: 0;
    margin-bottom: 52px;
  }

  .cf-handle-form,
  .cf-section,
  .cf-filter-grid {
    border-top: 1px solid var(--line);
  }

  .cf-handle-form {
    display: grid;
    grid-template-columns: minmax(280px, 620px) auto;
    gap: 18px;
    align-items: end;
    justify-content: start;
    min-width: 0;
    border-top: 0;
    padding-top: 0;
  }

  .cf-field {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .cf-field > span,
  .cf-fieldset legend {
    color: var(--muted);
    font-size: 13px;
    white-space: nowrap;
  }

  .cf-field input,
  .cf-field textarea,
  .cf-field select {
    width: 100%;
    min-width: 0;
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    padding: 4px 0 7px;
  }

  .cf-field textarea {
    overflow: hidden;
    resize: none;
    line-height: 1.55;
  }

  .cf-field input:focus,
  .cf-field textarea:focus,
  .cf-field select:focus {
    border-bottom-color: var(--text);
    outline: 0;
  }

  .cf-small-field {
    min-width: 120px;
  }

  .cf-form-actions,
  .cf-inline-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 18px;
    align-items: end;
  }

  .cf-tool button {
    border: 0;
    border-bottom: 1px solid transparent;
    border-radius: 0;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font: inherit;
    padding: 0 0 2px;
  }

  .cf-tool button:hover:not(:disabled) {
    border-bottom-color: currentColor;
  }

  .cf-tool button:focus-visible {
    outline: 1px solid var(--text);
    outline-offset: 3px;
  }

  .cf-tool button:disabled {
    color: var(--muted);
    cursor: wait;
    opacity: 0.6;
  }

  .cf-status {
    margin: -10px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  .cf-status[hidden],
  .cf-section[hidden] {
    display: none;
  }

  .cf-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    align-items: center;
    padding-bottom: 9px;
    border-bottom: 1px solid var(--line);
  }

  .cf-tab {
    color: var(--muted);
    white-space: nowrap;
  }

  .cf-tab.is-active {
    border-bottom-color: currentColor;
    color: var(--text);
    font-weight: 700;
  }

  .cf-tab-panel[hidden] {
    display: none;
  }

  .cf-tab-panel {
    border-top: 0;
  }

  .cf-section {
    display: grid;
    gap: 14px;
    min-width: 0;
    padding-top: 22px;
  }

  .cf-section-head {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    align-items: end;
    justify-content: space-between;
  }

  .cf-section-head-controls-only {
    justify-content: flex-start;
  }

  .cf-section-head h2 {
    margin: 0;
    font-size: 22px;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .cf-section-head p {
    max-width: 720px;
    margin: 5px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  .cf-panel-intro {
    max-width: 720px;
    margin: 0;
    color: var(--muted);
    font-size: 13px;
  }

  .cf-user-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px 20px;
  }

  .cf-user {
    min-width: 0;
    padding-top: 10px;
    border-top: 1px solid var(--line);
  }

  .cf-user strong {
    display: block;
    overflow-wrap: anywhere;
  }

  .cf-user span,
  .cf-empty,
  .cf-note {
    color: var(--muted);
    font-size: 13px;
  }

  .cf-empty {
    margin: 0;
  }

  .cf-chart {
    position: relative;
    min-height: 260px;
    min-width: 0;
    max-width: 100%;
    border-top: 1px solid var(--text);
    border-bottom: 1px solid var(--line);
    overflow-x: auto;
    padding: 10px 0 8px;
  }

  .cf-chart:empty {
    display: none;
  }

  .cf-chart:has(> .cf-empty) {
    min-height: 0;
    border-top: 0;
    border-bottom: 0;
    padding: 0;
  }

  .cf-chart-tooltip {
    position: absolute;
    z-index: 2;
    display: none;
    max-width: min(320px, calc(100% - 24px));
    border: 1px solid var(--text);
    background: var(--bg);
    color: var(--text);
    font-size: 12px;
    line-height: 1.45;
    pointer-events: none;
    padding: 8px 10px;
  }

  .cf-chart-tooltip.is-visible {
    display: block;
  }

  .cf-chart-tooltip strong {
    display: block;
    margin-bottom: 4px;
  }

  .cf-chart-tooltip span {
    display: block;
    color: var(--muted);
  }

  .cf-chart svg {
    display: block;
    min-width: 720px;
    width: 100%;
    height: auto;
  }

  .cf-chart-axis,
  .cf-chart-grid {
    stroke: var(--line);
    stroke-width: 1;
  }

  .cf-chart-label {
    fill: var(--muted);
    font-size: 12px;
  }

  .cf-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    margin-top: 10px;
    color: var(--muted);
    font-size: 13px;
  }

  .cf-legend span {
    display: inline-flex;
    gap: 6px;
    align-items: center;
  }

  .cf-legend i {
    display: inline-block;
    width: 18px;
    height: 2px;
  }

  .cf-performance-summary {
    min-width: 0;
    border-top: 1px solid var(--line);
    padding-top: 10px;
  }

  .cf-performance-summary:empty {
    display: none;
  }

  .cf-summary-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    margin: 0;
    color: var(--muted);
    font-size: 13px;
  }

  .cf-summary-list strong {
    color: var(--text);
  }

  .cf-table-wrap {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    overflow-x: auto;
  }

  .cf-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
    font-size: 13px;
    line-height: 1.4;
  }

  .cf-table-compact {
    min-width: 560px;
  }

  .cf-table th,
  .cf-table td {
    border-bottom: 1px solid var(--line);
    padding: 8px 9px;
    text-align: left;
    vertical-align: top;
  }

  .cf-table th {
    color: var(--muted);
    font-weight: 700;
    white-space: nowrap;
  }

  .cf-table td strong {
    overflow-wrap: anywhere;
  }

  .cf-num {
    text-align: right;
    white-space: nowrap;
  }

  .cf-filter-grid {
    display: grid;
    grid-template-columns: minmax(260px, 1fr) minmax(260px, 1fr) minmax(180px, 0.7fr);
    gap: 18px 26px;
    min-width: 0;
    padding-top: 16px;
  }

  .cf-fieldset {
    display: grid;
    gap: 8px;
    min-width: 0;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .cf-fieldset label:not(.cf-field) {
    display: flex;
    gap: 8px;
    align-items: baseline;
    color: #4b5563;
    font-size: 14px;
  }

  .cf-fieldset input[type="checkbox"] {
    accent-color: var(--text);
  }

  .cf-duration-fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .cf-summary-line {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    margin: 0;
    color: #4b5563;
  }

  .cf-summary-line strong {
    color: var(--text);
  }

  @media (max-width: 860px) {
    .cf-page {
      width: 100%;
      max-width: 100%;
      margin-right: 0;
      margin-left: 0;
    }

    .cf-heading h1 {
      font-size: 31px;
    }

    .cf-handle-form,
    .cf-filter-grid {
      grid-template-columns: 1fr;
    }

    .cf-form-actions,
    .cf-inline-controls {
      align-items: baseline;
    }
  }

  @media (max-width: 600px) {
    .cf-table-compact {
      min-width: 100%;
      table-layout: fixed;
    }

    .cf-table-compact th,
    .cf-table-compact td {
      overflow-wrap: anywhere;
      padding-right: 6px;
      padding-left: 6px;
    }

    .cf-table-compact th:first-child {
      width: 54px;
    }

    .cf-table-compact th:nth-child(3) {
      width: 58px;
    }

    .cf-table-compact th:last-child {
      width: 88px;
    }
  }
</style>
