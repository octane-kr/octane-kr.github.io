---
import BlogLayout from '../layouts/BlogLayout.astro';

const description =
  'UCPC archive Spotboard data를 특정 contest time 기준으로 다시 보는 정적 도구';
---

<BlogLayout title="UCPC Scoreboard" description={description}>
  <article class="ucpc-page">
    <header class="ucpc-heading">
      <h1>UCPC 스코어보드 타임머신</h1>
      <p>
        UCPC 버추얼 컨테스트를 돌 때 쓰려고 만든 정적 도구입니다.
        <a href="https://static.ucpc.me/archive/ucpc/">UCPC archive</a>의 Spotboard
        데이터를 특정 시점 기준으로 다시 계산합니다.
      </p>
      <p>
        프리즈 시각과 보고 싶은 시각을 넣으면 해당 시점의 스코어보드가 보이고,
        팀명 검색도 됩니다. 전부 Codex로 만든 것이라 오류가 있을 수 있습니다.
      </p>
    </header>

    <section class="ucpc-tool" aria-label="UCPC scoreboard time machine" data-ucpc-tool>
      <div class="ucpc-controls">
        <label class="ucpc-control ucpc-control-contest">
          <span>대회</span>
          <select data-scoreboard-select></select>
        </label>

        <label class="ucpc-control">
          <span>프리즈</span>
          <input
            data-freeze-time
            type="text"
            inputmode="numeric"
            placeholder="-"
            autocomplete="off"
          />
        </label>

        <label class="ucpc-control">
          <span>시각</span>
          <input
            data-current-time
            type="text"
            inputmode="numeric"
            value="0:00"
            autocomplete="off"
          />
        </label>

        <label class="ucpc-control ucpc-control-search">
          <span>검색</span>
          <input
            data-team-search
            type="search"
            autocomplete="off"
          />
        </label>
      </div>

      <div class="ucpc-status" aria-live="polite">
        <strong data-contest-title>Loading...</strong>
        <span data-scoreboard-meta></span>
      </div>

      <div class="ucpc-table-wrap" data-scoreboard-wrap>
        <table class="ucpc-scoreboard" data-scoreboard-table>
          <tbody data-scoreboard-body>
            <tr>
              <td>Loading...</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="ucpc-footnote" data-scoreboard-footnote></p>
      <p class="ucpc-error" data-scoreboard-error hidden></p>
    </section>
  </article>

  <script is:inline src="/ucpc-scoreboard/data/manifest.js"></script>
  <script is:inline src="/ucpc-scoreboard/app.js"></script>
</BlogLayout>

<style is:global>
  .ucpc-page {
    width: min(1160px, calc(100vw - 40px));
    margin-left: 50%;
    transform: translateX(-50%);
  }

  .ucpc-heading {
    margin-bottom: 26px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }

  .ucpc-heading h1 {
    margin: 0 0 10px;
    font-size: 38px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .ucpc-heading p {
    max-width: 820px;
    margin: 8px 0 0;
    color: #4b5563;
  }

  .ucpc-heading a {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ucpc-tool {
    margin-bottom: 48px;
  }

  .ucpc-controls {
    display: grid;
    grid-template-columns: minmax(260px, 1.5fr) minmax(108px, 0.55fr) minmax(108px, 0.55fr) minmax(180px, 1fr);
    gap: 14px 18px;
    align-items: end;
    margin-bottom: 20px;
  }

  .ucpc-control {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .ucpc-control span {
    color: var(--muted);
    font-size: 13px;
  }

  .ucpc-control select,
  .ucpc-control input {
    width: 100%;
    min-width: 0;
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    padding: 4px 0 7px;
  }

  .ucpc-control select:focus,
  .ucpc-control input:focus {
    border-bottom-color: var(--text);
    outline: 0;
  }

  .ucpc-control input.is-invalid {
    border-bottom-color: #b91c1c;
    color: #b91c1c;
  }

  .ucpc-status {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    align-items: baseline;
    margin-bottom: 12px;
  }

  .ucpc-status strong {
    font-size: 18px;
    letter-spacing: 0;
  }

  .ucpc-status span,
  .ucpc-footnote,
  .ucpc-error {
    color: var(--muted);
    font-size: 13px;
  }

  .ucpc-error {
    color: #b91c1c;
  }

  .ucpc-table-wrap {
    overflow: auto;
    border-top: 1px solid var(--text);
    border-bottom: 1px solid var(--line);
  }

  .ucpc-scoreboard {
    width: 100%;
    min-width: 980px;
    border-collapse: collapse;
    font-size: 13px;
    line-height: 1.35;
  }

  .ucpc-scoreboard th,
  .ucpc-scoreboard td {
    border-bottom: 1px solid var(--line);
    padding: 7px 8px;
    vertical-align: middle;
  }

  .ucpc-scoreboard th {
    position: sticky;
    top: 0;
    z-index: 1;
    background: #fff;
    color: var(--muted);
    font-weight: 700;
    text-align: left;
  }

  .ucpc-scoreboard tbody tr:hover {
    background: #fafafa;
  }

  .ucpc-rank,
  .ucpc-solved,
  .ucpc-penalty,
  .ucpc-problem {
    text-align: center;
    white-space: nowrap;
  }

  .ucpc-rank {
    width: 48px;
    color: var(--muted);
  }

  .ucpc-team {
    min-width: 280px;
  }

  .ucpc-team-name {
    display: block;
    font-weight: 700;
  }

  .ucpc-team-members {
    display: block;
    margin-top: 2px;
    color: var(--muted);
    font-size: 12px;
  }

  .ucpc-solved {
    width: 58px;
    font-weight: 800;
  }

  .ucpc-penalty {
    width: 74px;
    color: #4b5563;
  }

  .ucpc-problem {
    width: 44px;
    min-width: 44px;
    font-variant-numeric: tabular-nums;
  }

  .ucpc-problem-cell {
    font-weight: 800;
  }

  .ucpc-problem-empty {
    color: #cbd5e1;
  }

  .ucpc-problem-solved {
    background: #dcfce7;
    color: #166534;
  }

  .ucpc-problem-first {
    box-shadow: inset 0 -2px 0 #15803d;
  }

  .ucpc-problem-failed {
    background: #fee2e2;
    color: #991b1b;
  }

  .ucpc-problem-frozen,
  .ucpc-problem-pending {
    background: #fef3c7;
    color: #92400e;
  }

  .ucpc-footnote {
    margin: 12px 0 0;
  }

  @media (max-width: 840px) {
    .ucpc-page {
      width: min(100%, calc(100vw - 36px));
    }

    .ucpc-heading h1 {
      font-size: 30px;
    }

    .ucpc-controls {
      grid-template-columns: 1fr 1fr;
    }

    .ucpc-control-contest,
    .ucpc-control-search {
      grid-column: 1 / -1;
    }
  }
</style>
