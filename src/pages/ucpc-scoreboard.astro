---
import BlogLayout from '../layouts/BlogLayout.astro';

const description =
  'UCPC archive Spotboard data를 특정 contest time 기준으로 다시 보는 스코어보드';
---

<BlogLayout title="UCPC 동적 스코어보드" description={description}>
  <article class="ucpc-page">
    <header class="ucpc-heading">
      <h1>UCPC 동적 스코어보드</h1>
      <p>
        UCPC 버추얼 컨테스트를 위한 스코어보드입니다.
        <a href="https://static.ucpc.me/">UCPC archive</a>에서 원본 스코어보드를
        확인할 수 있습니다.
      </p>
      <p>
        <strong>경과</strong> 모드에서는 대회 시작으로부터 특정 시간이 지난
        시점의 스코어보드를 확인할 수 있습니다. <strong>시계</strong> 모드에서는
        버추얼 컨테스트를 시작한 시각과 현재 시각을 입력하면 대회 시작으로부터
        지난 시간이 자동으로 계산됩니다.
      </p>
      <p>
        프리즈 시각에는 스코어보드가 대회 시작 후 몇 분 뒤에 프리즈되는지
        입력하면 됩니다. 공란으로 두면 프리즈가 적용되지 않은 스코어보드를 확인할
        수 있습니다.
      </p>
      <p>
        이 기능은 모두 Codex를 이용해 개발했기 때문에 예상치 못한 오류나 틀린
        데이터가 있을 수 있습니다. 참고용으로만 사용해주세요.
      </p>
    </header>

    <section class="ucpc-tool" aria-label="UCPC dynamic scoreboard" data-ucpc-tool>
      <div class="ucpc-controls">
        <label class="ucpc-control ucpc-control-contest">
          <span>대회</span>
          <select data-scoreboard-select></select>
        </label>

        <label class="ucpc-control">
          <span>프리즈</span>
          <input
            data-freeze-time
            type="text"
            inputmode="numeric"
            placeholder="-"
            autocomplete="off"
          />
        </label>

        <div class="ucpc-mode-control" role="group" aria-label="시간 입력 모드">
          <button
            class="ucpc-mode-button is-active"
            type="button"
            data-time-mode="elapsed"
            aria-pressed="true"
          >
            경과
          </button>
          <button
            class="ucpc-mode-button"
            type="button"
            data-time-mode="clock"
            aria-pressed="false"
          >
            시계
          </button>
        </div>

        <div class="ucpc-time-fields" data-time-panel="elapsed">
          <label class="ucpc-control">
            <span>시각</span>
            <input
              data-current-time
              type="text"
              inputmode="numeric"
              value="0:00"
              autocomplete="off"
            />
          </label>
        </div>

        <div class="ucpc-time-fields ucpc-clock-fields" data-time-panel="clock" hidden>
          <label class="ucpc-control">
            <span>시작 시간</span>
            <input
              data-start-clock-time
              type="text"
              inputmode="numeric"
              value="0:00"
              autocomplete="off"
            />
          </label>
          <label class="ucpc-control">
            <span>현재 시간</span>
            <input
              data-current-clock-time
              type="text"
              inputmode="numeric"
              value="0:00"
              autocomplete="off"
            />
          </label>
        </div>

        <label class="ucpc-control ucpc-control-search">
          <span>검색</span>
          <input
            data-team-search
            type="search"
            autocomplete="off"
          />
        </label>
      </div>

      <div class="ucpc-status" aria-live="polite">
        <strong data-contest-title>Loading...</strong>
        <span data-scoreboard-meta></span>
      </div>
      <p class="ucpc-computed-time" data-computed-time></p>

      <div class="ucpc-table-wrap" data-scoreboard-wrap>
        <table class="ucpc-scoreboard" data-scoreboard-table>
          <tbody data-scoreboard-body>
            <tr>
              <td>Loading...</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="ucpc-footnote" data-scoreboard-footnote></p>
      <p class="ucpc-error" data-scoreboard-error hidden></p>
    </section>
  </article>

  <script is:inline src="/ucpc-scoreboard/data/manifest.js"></script>
  <script is:inline src="/ucpc-scoreboard/app.js"></script>
</BlogLayout>

<style is:global>
  .ucpc-page {
    --ucpc-work-width: min(1160px, calc(100vw - 40px));
    width: var(--ucpc-work-width);
    max-width: none;
    margin: 0 auto;
  }

  .ucpc-heading {
    margin-bottom: 26px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }

  .ucpc-heading h1 {
    margin: 0 0 10px;
    font-size: 38px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .ucpc-heading p {
    max-width: 100%;
    margin: 8px 0 0;
    color: #4b5563;
  }

  .ucpc-heading a {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ucpc-tool {
    margin-bottom: 48px;
  }

  .ucpc-controls {
    display: grid;
    grid-template-columns: minmax(220px, 1.35fr) minmax(96px, 0.55fr) auto minmax(220px, 0.9fr) minmax(160px, 1fr);
    gap: 14px 18px;
    align-items: end;
    margin-bottom: 20px;
  }

  .ucpc-control {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .ucpc-control span {
    color: var(--muted);
    font-size: 13px;
    white-space: nowrap;
  }

  .ucpc-control select,
  .ucpc-control input {
    width: 100%;
    min-width: 0;
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    padding: 4px 0 7px;
  }

  .ucpc-control select:focus,
  .ucpc-control input:focus {
    border-bottom-color: var(--text);
    outline: 0;
  }

  .ucpc-control input.is-invalid {
    border-bottom-color: #b91c1c;
    color: #b91c1c;
  }

  .ucpc-mode-control {
    display: inline-flex;
    align-items: baseline;
    padding-bottom: 7px;
    color: var(--muted);
    white-space: nowrap;
  }

  .ucpc-mode-button {
    border: 0;
    border-bottom: 1px solid transparent;
    border-radius: 0;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    padding: 0 0 2px;
  }

  .ucpc-mode-button + .ucpc-mode-button {
    position: relative;
    margin-left: 20px;
  }

  .ucpc-mode-button + .ucpc-mode-button::before {
    content: "/";
    position: absolute;
    left: -13px;
    color: var(--muted);
    pointer-events: none;
  }

  .ucpc-mode-button:hover,
  .ucpc-mode-button.is-active {
    color: var(--text);
  }

  .ucpc-mode-button.is-active {
    border-bottom-color: var(--text);
    font-weight: 700;
  }

  .ucpc-mode-button:focus-visible {
    outline: 1px solid var(--text);
    outline-offset: 3px;
  }

  .ucpc-time-fields {
    display: grid;
    min-width: 0;
  }

  .ucpc-time-fields[hidden] {
    display: none;
  }

  .ucpc-clock-fields {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .ucpc-status {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    align-items: baseline;
    margin-bottom: 12px;
  }

  .ucpc-status strong {
    font-size: 18px;
    letter-spacing: 0;
  }

  .ucpc-status span,
  .ucpc-computed-time,
  .ucpc-footnote,
  .ucpc-error {
    color: var(--muted);
    font-size: 13px;
  }

  .ucpc-computed-time {
    min-height: 1.35em;
    margin: -4px 0 10px;
  }

  .ucpc-error {
    color: #b91c1c;
  }

  .ucpc-table-wrap {
    width: 100%;
    overflow: auto;
    border-top: 1px solid var(--text);
    border-bottom: 1px solid var(--line);
  }

  .ucpc-scoreboard {
    width: 100%;
    min-width: 980px;
    border-collapse: collapse;
    font-size: 13px;
    line-height: 1.35;
  }

  .ucpc-scoreboard th,
  .ucpc-scoreboard td {
    border-bottom: 1px solid var(--line);
    padding: 7px 8px;
    vertical-align: middle;
  }

  .ucpc-scoreboard th {
    position: sticky;
    top: 0;
    z-index: 1;
    background: #fff;
    color: var(--muted);
    font-weight: 700;
    text-align: left;
  }

  .ucpc-scoreboard tbody tr:hover {
    background: #fafafa;
  }

  .ucpc-rank,
  .ucpc-solved,
  .ucpc-penalty,
  .ucpc-problem {
    text-align: center;
    white-space: nowrap;
  }

  .ucpc-rank {
    width: 48px;
    color: var(--muted);
  }

  .ucpc-team {
    min-width: 280px;
  }

  .ucpc-team-name {
    display: block;
    font-weight: 700;
  }

  .ucpc-team-members {
    display: block;
    margin-top: 2px;
    color: var(--muted);
    font-size: 12px;
  }

  .ucpc-solved {
    width: 58px;
    font-weight: 800;
  }

  .ucpc-penalty {
    width: 74px;
    color: #4b5563;
  }

  .ucpc-problem {
    width: 44px;
    min-width: 44px;
    font-variant-numeric: tabular-nums;
  }

  .ucpc-problem-cell {
    font-weight: 800;
  }

  .ucpc-problem-empty {
    color: #cbd5e1;
  }

  .ucpc-problem-solved {
    background: #dcfce7;
    color: #166534;
  }

  .ucpc-problem-first {
    box-shadow: inset 0 -2px 0 #15803d;
  }

  .ucpc-problem-failed {
    background: #fee2e2;
    color: #991b1b;
  }

  .ucpc-problem-frozen,
  .ucpc-problem-pending {
    background: #fef3c7;
    color: #92400e;
  }

  .ucpc-footnote {
    margin: 12px 0 0;
  }

  @media (max-width: 840px) {
    .ucpc-page {
      width: 100%;
      max-width: 100%;
    }

    .ucpc-heading h1 {
      font-size: 30px;
    }

    .ucpc-controls {
      grid-template-columns: 1fr 1fr;
    }

    .ucpc-control-contest,
    .ucpc-mode-control,
    .ucpc-time-fields,
    .ucpc-control-search {
      grid-column: 1 / -1;
    }
  }
</style>
