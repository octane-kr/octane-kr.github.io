---
import BlogLayout from '../layouts/BlogLayout.astro';

const description =
  'UCPC Archive의 Spotboard 데이터를 이용해 원하는 시점의 스코어보드를 보여주는 도구';
const assetVersion = Date.now().toString(36);
---

<BlogLayout title="UCPC 동적 스코어보드" description={description}>
  <article class="ucpc-page">
    <header class="ucpc-heading">
      <h1>UCPC 동적 스코어보드</h1>
      <p>
        UCPC 버추얼 컨테스트를 위한 스코어보드입니다.
        <a href="https://static.ucpc.me/">UCPC archive</a>에서 원본 스코어보드를
        확인할 수 있습니다.
      </p>
      <p>
        <strong>경과</strong> 모드에서는 대회 시작 후 원하는 경과 시간의
        스코어보드를 확인할 수 있습니다. <strong>시계</strong> 모드에서는 버추얼
        컨테스트의 시작 시각과 현재 시각으로 경과 시간을 계산합니다.
      </p>
      <p>
        프리즈가 시작되는 시점을 대회 시작 후 경과 시간으로 입력하면 됩니다.
        공란으로 두면 프리즈가 적용되지 않은 스코어보드를 확인할 수 있습니다.
      </p>
      <p>
        이 도구는 Codex를 이용해 개발했기 때문에 예상치 못한 오류나 잘못된 데이터가
        있을 수 있습니다. 참고용으로만 사용해 주세요.
      </p>
    </header>

    <section
      class="ucpc-tool"
      aria-label="UCPC 동적 스코어보드"
      data-ucpc-tool
      data-asset-version={assetVersion}
    >
      <div class="ucpc-controls">
        <label class="ucpc-control ucpc-control-contest">
          <span>대회</span>
          <select data-scoreboard-select></select>
        </label>

        <label class="ucpc-control">
          <span>프리즈 시점</span>
          <input
            data-freeze-time
            type="text"
            placeholder="-"
            autocomplete="off"
          />
        </label>

        <div class="ucpc-mode-control" role="group" aria-label="시간 입력 방식">
          <button
            class="ucpc-mode-button is-active"
            type="button"
            data-time-mode="elapsed"
            aria-pressed="true"
          >
            경과
          </button>
          <button
            class="ucpc-mode-button"
            type="button"
            data-time-mode="clock"
            aria-pressed="false"
          >
            시계
          </button>
        </div>

        <div class="ucpc-time-fields" data-time-panel="elapsed">
          <label class="ucpc-control">
            <span>경과 시간</span>
            <input
              data-current-time
              type="text"
              value="0:00"
              autocomplete="off"
            />
          </label>
        </div>

        <div class="ucpc-time-fields ucpc-clock-fields" data-time-panel="clock" hidden>
          <label class="ucpc-control">
            <span>시작 시각</span>
            <input
              data-start-clock-time
              type="time"
              step="60"
              autocomplete="off"
            />
          </label>
          <div class="ucpc-clock-current">
            <label class="ucpc-control">
              <span>현재 시각</span>
              <input
                data-current-clock-time
                type="time"
                step="60"
                autocomplete="off"
              />
            </label>
            <button
              class="ucpc-refresh-button"
              type="button"
              data-refresh-current-time
              aria-label="현재 시각으로 갱신"
              title="현재 시각으로 갱신"
            >
              <span aria-hidden="true">↻</span>
            </button>
          </div>
        </div>

        <button class="ucpc-apply-button" type="button" data-apply-time>보기</button>

        <label class="ucpc-control ucpc-control-search">
          <span>검색</span>
          <input
            data-team-search
            type="search"
            autocomplete="off"
          />
        </label>
      </div>

      <div class="ucpc-status" aria-live="polite">
        <strong data-contest-title>불러오는 중...</strong>
        <span data-scoreboard-meta></span>
      </div>
      <p class="ucpc-computed-time" data-computed-time></p>

      <div class="ucpc-table-wrap" data-scoreboard-wrap>
        <table class="ucpc-scoreboard" data-scoreboard-table>
          <tbody data-scoreboard-body>
            <tr>
              <td>불러오는 중...</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="ucpc-footnote" data-scoreboard-footnote></p>
      <p class="ucpc-error" data-scoreboard-error hidden></p>
    </section>
  </article>

  <script is:inline src={`/ucpc-scoreboard/data/manifest.js?v=${assetVersion}`}></script>
  <script is:inline src={`/ucpc-scoreboard/data/unofficial-overlays.js?v=${assetVersion}`}></script>
  <script is:inline src={`/ucpc-scoreboard/app.js?v=${assetVersion}`}></script>
</BlogLayout>

<style is:global>
  .ucpc-page {
    --ucpc-work-width: min(1160px, calc(100vw - 40px));
    width: var(--ucpc-work-width);
    max-width: none;
    margin-left: calc(50% - var(--ucpc-work-width) / 2);
    margin-right: calc(50% - var(--ucpc-work-width) / 2);
  }

  .ucpc-heading {
    margin-bottom: 26px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }

  .ucpc-heading h1 {
    margin: 0 0 10px;
    font-size: 38px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .ucpc-heading p {
    max-width: 100%;
    margin: 8px 0 0;
    color: #4b5563;
    word-break: keep-all;
  }

  .ucpc-heading a {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ucpc-tool {
    margin-bottom: 48px;
  }

  .ucpc-controls {
    display: grid;
    grid-template-columns: minmax(190px, 1.05fr) minmax(108px, 0.55fr) auto minmax(320px, 1.25fr) auto minmax(140px, 0.8fr);
    gap: 14px 18px;
    align-items: end;
    margin-bottom: 20px;
  }

  .ucpc-control {
    display: grid;
    gap: 5px;
    min-width: 0;
  }

  .ucpc-control span {
    color: var(--muted);
    font-size: 13px;
    white-space: nowrap;
  }

  .ucpc-control select,
  .ucpc-control input {
    width: 100%;
    min-width: 0;
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    padding: 4px 0 7px;
  }

  .ucpc-control select:focus,
  .ucpc-control input:focus {
    border-bottom-color: var(--text);
    outline: 0;
  }

  .ucpc-control input.is-invalid {
    border-bottom-color: #b91c1c;
    color: #b91c1c;
  }

  .ucpc-mode-control {
    display: inline-flex;
    align-items: baseline;
    padding-bottom: 7px;
    color: var(--muted);
    white-space: nowrap;
  }

  .ucpc-mode-button {
    border: 0;
    border-bottom: 1px solid transparent;
    border-radius: 0;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    padding: 0 0 2px;
  }

  .ucpc-mode-button + .ucpc-mode-button {
    position: relative;
    margin-left: 20px;
  }

  .ucpc-mode-button + .ucpc-mode-button::before {
    content: "/";
    position: absolute;
    left: -13px;
    color: var(--muted);
    pointer-events: none;
  }

  .ucpc-mode-button:hover,
  .ucpc-mode-button.is-active {
    color: var(--text);
  }

  .ucpc-mode-button.is-active {
    border-bottom-color: var(--text);
    font-weight: 700;
  }

  .ucpc-mode-button:focus-visible {
    outline: 1px solid var(--text);
    outline-offset: 3px;
  }

  .ucpc-time-fields {
    display: grid;
    min-width: 0;
  }

  .ucpc-time-fields[hidden] {
    display: none;
  }

  .ucpc-clock-fields {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .ucpc-clock-current {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 30px;
    gap: 6px;
    align-items: end;
    min-width: 0;
  }

  .ucpc-refresh-button,
  .ucpc-apply-button {
    border: 0;
    border-bottom: 1px solid var(--line);
    border-radius: 0;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font: inherit;
  }

  .ucpc-refresh-button {
    width: 30px;
    height: 33px;
    padding: 0;
    font-size: 19px;
    line-height: 1;
  }

  .ucpc-apply-button {
    min-width: 56px;
    height: 33px;
    padding: 0 10px;
    font-weight: 700;
  }

  .ucpc-refresh-button:hover,
  .ucpc-apply-button:hover,
  .ucpc-refresh-button:focus-visible,
  .ucpc-apply-button:focus-visible {
    border-bottom-color: var(--text);
    outline: 0;
  }

  .ucpc-status {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    align-items: baseline;
    margin-bottom: 12px;
  }

  .ucpc-status strong {
    font-size: 18px;
    letter-spacing: 0;
  }

  .ucpc-status span,
  .ucpc-computed-time,
  .ucpc-footnote,
  .ucpc-error {
    color: var(--muted);
    font-size: 13px;
  }

  .ucpc-computed-time {
    min-height: 1.35em;
    margin: -4px 0 10px;
  }

  .ucpc-error {
    color: #b91c1c;
  }

  .ucpc-table-wrap {
    width: 100%;
    overflow: auto;
    border-top: 1px solid var(--text);
    border-bottom: 1px solid var(--line);
  }

  .ucpc-scoreboard {
    width: 100%;
    min-width: 980px;
    border-collapse: collapse;
    font-size: 13px;
    line-height: 1.35;
  }

  .ucpc-scoreboard th,
  .ucpc-scoreboard td {
    border-bottom: 1px solid var(--line);
    padding: 7px 8px;
    vertical-align: middle;
  }

  .ucpc-scoreboard th {
    position: sticky;
    top: 0;
    z-index: 1;
    background: #fff;
    color: var(--muted);
    font-weight: 700;
    text-align: left;
  }

  .ucpc-scoreboard tbody tr:hover {
    background: #fafafa;
  }

  .ucpc-scoreboard tbody tr.ucpc-team-unofficial {
    background: #f6f7f8;
  }

  .ucpc-scoreboard tbody tr.ucpc-team-unofficial:hover {
    background: #f1f3f5;
  }

  .ucpc-rank,
  .ucpc-solved,
  .ucpc-penalty,
  .ucpc-problem {
    text-align: center;
    white-space: nowrap;
  }

  .ucpc-rank {
    width: 48px;
    color: var(--muted);
  }

  .ucpc-team {
    min-width: 280px;
  }

  .ucpc-team-name {
    display: block;
    font-weight: 700;
  }

  .ucpc-team-members {
    display: block;
    margin-top: 2px;
    color: var(--muted);
    font-size: 12px;
  }

  .ucpc-solved {
    width: 58px;
    font-weight: 800;
  }

  .ucpc-penalty {
    width: 74px;
    color: #4b5563;
  }

  .ucpc-problem {
    width: 44px;
    min-width: 44px;
    font-variant-numeric: tabular-nums;
  }

  .ucpc-problem-cell {
    font-weight: 800;
  }

  .ucpc-problem-empty {
    color: #cbd5e1;
  }

  .ucpc-problem-solved {
    background: #dcfce7;
    color: #166534;
  }

  .ucpc-problem-first {
    box-shadow: inset 0 -2px 0 #15803d;
  }

  .ucpc-problem-failed {
    background: #fee2e2;
    color: #991b1b;
  }

  .ucpc-problem-frozen,
  .ucpc-problem-pending {
    background: #fef3c7;
    color: #92400e;
  }

  .ucpc-footnote {
    margin: 12px 0 0;
  }

  .ucpc-footnote a {
    color: var(--link);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 1040px) {
    .ucpc-controls {
      grid-template-columns: 1fr 1fr;
    }

    .ucpc-control-contest,
    .ucpc-mode-control,
    .ucpc-time-fields,
    .ucpc-apply-button,
    .ucpc-control-search {
      grid-column: 1 / -1;
    }

    .ucpc-apply-button {
      width: 100%;
    }
  }

  @media (max-width: 840px) {
    .ucpc-page {
      width: 100%;
      max-width: 100%;
      margin-right: 0;
      margin-left: 0;
    }

    .ucpc-heading h1 {
      font-size: 30px;
    }
  }
</style>
