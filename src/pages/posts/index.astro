---
import BlogLayout from '../../layouts/BlogLayout.astro';
import categoriesText from '../../data/categories.txt?raw';

type CategoryGroup = {
  category: string;
  subcategories: string[];
};

const categoryStructure = categoriesText
  .split(/\r?\n/)
  .map((line) => line.trim())
  .filter((line) => line && !line.startsWith('#'))
  .reduce<CategoryGroup[]>((groups, line) => {
    if (line.startsWith('-')) {
      const subcategory = line.replace(/^-+\s*/, '').trim();

      if (subcategory && groups.length > 0) {
        groups[groups.length - 1].subcategories.push(subcategory);
      }

      return groups;
    }

    groups.push({
      category: line,
      subcategories: [],
    });

    return groups;
  }, []);

type PostSearchEntry = {
  slug: string;
  title: string;
  category: string;
  publishedAt: string;
  updatedAt: string;
  titleText: string;
  bodyText: string;
};

const modules = import.meta.glob('./*.md', { eager: true });
const rawModules = import.meta.glob<string>('./*.md', {
  eager: true,
  query: '?raw',
  import: 'default',
});

const normalizeSearchText = (value: string) =>
  value.normalize('NFKC').toLowerCase().replace(/\s+/gu, '');

const removeFrontmatter = (markdown: string) =>
  markdown.replace(/^\uFEFF?---\r?\n[\s\S]*?\r?\n---\s*/u, '');

const removeLensMarkerComments = (markdown: string) =>
  markdown
    .split(/\r?\n/)
    .filter(
      (line) =>
        !/^\s*<!--\s*lens:[^\r\n]*-->\s*$/u.test(line) &&
        !/^\s*<!--\s*\/lens\s*-->\s*$/u.test(line),
    )
    .join('\n');

const stripMarkdownForSearch = (markdown: string) =>
  removeLensMarkerComments(removeFrontmatter(markdown))
    .replace(/^\s*(```|~~~).*$/gmu, ' ')
    .replace(/!\[([^\]]*)\]\([^)]+\)/gu, '$1')
    .replace(/\[([^\]]+)\]\([^)]+\)/gu, '$1')
    .replace(/`([^`]+)`/gu, '$1')
    .replace(/<!--[\s\S]*?-->/gu, ' ')
    .replace(/^\s{0,3}#{1,6}\s+/gmu, '')
    .replace(/^\s{0,3}>\s?/gmu, '')
    .replace(/^\s{0,3}(?:[-*+]|\d+[.)])\s+/gmu, '')
    .replace(/[*_~]/gu, '')
    .replace(/[()[\]{}|\\]/gu, ' ')
    .replace(/<[^>\n]+>/gu, ' ');

const stringifyDateValue = (value: unknown) => {
  if (!value) return '';
  if (value instanceof Date) return value.toISOString();

  return String(value);
};

const parseDate = (value: unknown, isDateOnly = false) => {
  if (!value) return null;

  if (isDateOnly) {
    const dateText =
      value instanceof Date ? value.toISOString().slice(0, 10) : String(value).slice(0, 10);
    const date = new Date(`${dateText}T00:00:00+09:00`);
    return Number.isNaN(date.valueOf()) ? null : date;
  }

  const date =
    value instanceof Date ? value : new Date(value as string | number);
  return Number.isNaN(date.valueOf()) ? null : date;
};

const dateFormatter = new Intl.DateTimeFormat('ko-KR', {
  timeZone: 'Asia/Seoul',
  year: 'numeric',
  month: 'numeric',
  day: 'numeric',
});

const posts = Object.entries(modules)
  .map(([path, rawModule]) => {
    const module = rawModule as any;
    const frontmatter = module.frontmatter ?? {};

    const filename = path.split('/').pop() ?? 'untitled.md';
    const slug = filename.replace(/\.md$/, '');

    const date = parseDate(
      frontmatter.publishedAt ?? frontmatter.date,
      !frontmatter.publishedAt,
    );
    const hasValidDate = date !== null;
    const title = String(frontmatter.title ?? slug);
    const category = String(frontmatter.category ?? 'PS');
    const subcategory = String(frontmatter.subcategory ?? '');

    return {
      url: module.url ?? `/posts/${slug}/`,
      slug,
      title,
      description: String(frontmatter.description ?? ''),
      category,
      subcategory,
      publishedAt: frontmatter.publishedAt ?? frontmatter.date,
      updatedAt: frontmatter.updatedAt,
      date,
      hasValidDate,
      draft: frontmatter.draft === true,
    };
  })
  .filter((post) => !post.draft)
  .sort((a, b) => {
    const av = a.hasValidDate ? a.date!.valueOf() : 0;
    const bv = b.hasValidDate ? b.date!.valueOf() : 0;
    if (bv !== av) return bv - av;

    return a.slug.localeCompare(b.slug) || a.title.localeCompare(b.title);
  });

const formatDate = (date: Date | null, hasValidDate: boolean) => {
  if (!hasValidDate || date === null) return '날짜 없음';

  return dateFormatter.format(date);
};

const formatCategory = (category: string, subcategory: string) =>
  subcategory ? `${category} / ${subcategory}` : category;

const postSearchIndex: PostSearchEntry[] = posts.map((post) => {
  const rawMarkdown = rawModules[`./${post.slug}.md`] ?? '';
  const bodyText = stripMarkdownForSearch(rawMarkdown);

  return {
    slug: post.slug,
    title: post.title,
    category: post.category,
    publishedAt: stringifyDateValue(post.publishedAt),
    updatedAt: stringifyDateValue(post.updatedAt),
    titleText: normalizeSearchText(post.title),
    bodyText: normalizeSearchText(bodyText),
  };
});

const postSearchIndexJson = JSON.stringify(postSearchIndex).replace(/</gu, '\\u003c');
---

<BlogLayout title="Posts" description="글 목록">
  <section class="hero">
    <h1>Posts</h1>
  </section>

  <section class="post-search-section" aria-label="글 검색">
    <div class="post-search-controls">
      <input
        class="post-search-input"
        type="search"
        placeholder="글 검색"
        aria-label="글 검색"
        autocomplete="off"
        data-post-search-input
      />

      <div class="post-search-mode" role="group" aria-label="검색 범위">
        <button
          class="post-search-mode-button is-active"
          type="button"
          aria-label="제목만"
          data-search-mode="title"
          aria-pressed="true"
        >
          제목만
        </button>
        <button
          class="post-search-mode-button"
          type="button"
          aria-label="본문까지"
          data-search-mode="body"
          aria-pressed="false"
        >
          본문까지
        </button>
      </div>
    </div>
    <p class="post-search-count" data-search-count hidden></p>
  </section>

  <section class="category-section" aria-label="카테고리 필터">
    <nav class="category-primary" aria-label="글 카테고리">
      <button
        class="category-filter is-active"
        type="button"
        data-filter-button
        data-filter-level="category"
        data-category=""
        data-subcategory=""
        aria-pressed="true"
      >
        All
      </button>
      {
        categoryStructure.map(({ category }) => (
          <button
            class="category-filter"
            type="button"
            data-filter-button
            data-filter-level="category"
            data-category={category}
            data-subcategory=""
            aria-pressed="false"
          >
            {category}
          </button>
        ))
      }
    </nav>

    {
      categoryStructure
        .filter(({ subcategories }) => subcategories.length > 0)
        .map(({ category, subcategories }) => (
          <div
            class="category-secondary"
            data-subcategory-group={category}
            hidden
          >
            {subcategories.map((subcategory) => (
              <button
                class="category-filter"
                type="button"
                data-filter-button
                data-filter-level="subcategory"
                data-category={category}
                data-subcategory={subcategory}
                aria-pressed="false"
              >
                {subcategory}
              </button>
            ))}
          </div>
        ))
    }
  </section>

  <section class="post-list-section" aria-label="글 목록">
    <p class="empty-state" data-empty-state hidden={posts.length > 0}>
      아직 작성된 글이 없습니다.
    </p>

    <div class="post-list" data-post-list>
      {
        posts.map((post) => (
          <article
            class="post-card"
            data-post-card
            data-post-slug={post.slug}
            data-category={post.category}
            data-subcategory={post.subcategory}
          >
            <a class="post-title" href={post.url}>
              {post.title}
            </a>

            <div class="post-meta">
              <span class="post-meta-main">
                <span>{formatCategory(post.category, post.subcategory)}</span>
                <span>{formatDate(post.date, post.hasValidDate)}</span>
              </span>
              <span
                class="post-list-stats"
                data-post-list-stats
                data-post-slug={post.slug}
                hidden
              >
                <span class="post-list-stat" aria-label="좋아요" data-post-list-like hidden>
                  <span aria-hidden="true">♡</span>
                  <span data-post-list-like-count>0</span>
                </span>
                <span class="post-list-stat" aria-label="댓글" data-post-list-comments hidden>
                  <span aria-hidden="true">댓글</span>
                  <span data-post-list-comment-count>0</span>
                </span>
              </span>
            </div>

            {post.description && (
              <p class="post-description">{post.description}</p>
            )}
          </article>
        ))
      }
    </div>

    <nav class="pagination" data-pagination hidden aria-label="글 페이지">
      <button type="button" data-page-prev>이전</button>
      <span data-page-status></span>
      <button type="button" data-page-next>다음</button>
    </nav>
  </section>

  <script
    type="application/json"
    data-post-search-index
    set:html={postSearchIndexJson}
  ></script>

  <script>
    import '../../scripts/postListStats.ts';

    const pageSize = 10;
    const filters = Array.from(document.querySelectorAll('[data-filter-button]'));
    const subcategoryGroups = Array.from(
      document.querySelectorAll('[data-subcategory-group]'),
    );
    const cards = Array.from(document.querySelectorAll('[data-post-card]'));
    const searchIndexElement = document.querySelector('[data-post-search-index]');
    const searchInput = document.querySelector('[data-post-search-input]');
    const searchModeButtons = Array.from(document.querySelectorAll('[data-search-mode]'));
    const searchCount = document.querySelector('[data-search-count]');
    const emptyState = document.querySelector('[data-empty-state]');
    const pagination = document.querySelector('[data-pagination]');
    const prevButton = document.querySelector('[data-page-prev]');
    const nextButton = document.querySelector('[data-page-next]');
    const pageStatus = document.querySelector('[data-page-status]');

    const params = new URLSearchParams(window.location.search);

    let activeCategory = params.get('category') ?? '';
    let activeSubcategory = params.get('subcategory') ?? '';
    let currentPage = 1;
    let searchMode = 'title';
    let searchQuery = '';

    const defaultEmptyText = emptyState?.textContent ?? '';

    const postSearchIndex = JSON.parse(searchIndexElement?.textContent ?? '[]');
    const searchEntries = new Map(
      postSearchIndex.map((entry) => [entry.slug, entry]),
    );

    const normalizeSearchText = (value) =>
      value.normalize('NFKC').toLowerCase().replace(/\s+/gu, '');

    const matchesCategory = (card) => {
      if (!activeCategory) return true;
      if (card.dataset.category !== activeCategory) return false;
      if (!activeSubcategory) return true;

      return card.dataset.subcategory === activeSubcategory;
    };

    const matchesSearch = (card) => {
      if (!searchQuery) return true;

      const postSlug = card.dataset.postSlug ?? '';
      const entry = searchEntries.get(postSlug);
      if (!entry) return false;

      const haystack =
        searchMode === 'body'
          ? `${entry.titleText}${entry.bodyText}`
          : entry.titleText;

      return haystack.includes(searchQuery);
    };

    const getMatchingCards = () =>
      cards.filter((card) => {
        if (!(card instanceof HTMLElement)) return false;

        return matchesCategory(card) && matchesSearch(card);
      });

    const syncActiveFilter = () => {
      filters.forEach((filter) => {
        filter.classList.remove('is-active');
        filter.setAttribute('aria-pressed', 'false');
      });

      const categoryButtons = filters.filter(
        (filter) =>
          filter instanceof HTMLElement &&
          filter.dataset.filterLevel === 'category',
      );
      let activeCategoryButton = categoryButtons.find(
        (filter) =>
          filter instanceof HTMLElement &&
          (filter.dataset.category ?? '') === activeCategory,
      );

      if (!activeCategoryButton) {
        activeCategory = '';
        activeSubcategory = '';
        activeCategoryButton = categoryButtons[0];
      }

      let activeSubcategoryButton = filters.find(
        (filter) =>
          filter instanceof HTMLElement &&
          filter.dataset.filterLevel === 'subcategory' &&
          (filter.dataset.category ?? '') === activeCategory &&
          (filter.dataset.subcategory ?? '') === activeSubcategory,
      );

      if (activeSubcategory && !activeSubcategoryButton) {
        activeSubcategory = '';
        activeSubcategoryButton = undefined;
      }

      activeCategoryButton?.classList.add('is-active');
      activeSubcategoryButton?.classList.add('is-active');
      activeCategoryButton?.setAttribute('aria-pressed', 'true');
      activeSubcategoryButton?.setAttribute('aria-pressed', 'true');

      subcategoryGroups.forEach((group) => {
        if (!(group instanceof HTMLElement)) return;
        group.hidden = group.dataset.subcategoryGroup !== activeCategory;
      });
    };

    const syncActiveSearchMode = () => {
      searchModeButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;

        const isActive = button.dataset.searchMode === searchMode;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-pressed', String(isActive));
      });
    };

    const updateFilterUrl = () => {
      const url = new URL(window.location.href);

      if (activeCategory) {
        url.searchParams.set('category', activeCategory);
      } else {
        url.searchParams.delete('category');
      }

      if (activeSubcategory) {
        url.searchParams.set('subcategory', activeSubcategory);
      } else {
        url.searchParams.delete('subcategory');
      }

      window.history.replaceState(null, '', url);
    };

    const renderPosts = () => {
      syncActiveFilter();
      syncActiveSearchMode();

      const matchingCards = getMatchingCards();
      const totalPages = Math.max(1, Math.ceil(matchingCards.length / pageSize));

      currentPage = Math.min(currentPage, totalPages);

      const firstVisibleIndex = (currentPage - 1) * pageSize;
      const visibleCards = new Set(
        matchingCards.slice(firstVisibleIndex, firstVisibleIndex + pageSize),
      );

      cards.forEach((card) => {
        if (card instanceof HTMLElement) {
          card.hidden = !visibleCards.has(card);
        }
      });

      if (emptyState instanceof HTMLElement) {
        emptyState.hidden = matchingCards.length > 0;
        emptyState.textContent = searchQuery
          ? '검색 결과가 없습니다.'
          : defaultEmptyText;
      }

      if (searchCount instanceof HTMLElement) {
        searchCount.hidden = !searchQuery;
        searchCount.textContent = searchQuery
          ? `검색 결과 ${matchingCards.length}개`
          : '';
      }

      if (pagination instanceof HTMLElement) {
        pagination.hidden = matchingCards.length <= pageSize;
      }

      if (prevButton instanceof HTMLButtonElement) {
        prevButton.disabled = currentPage <= 1;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = currentPage >= totalPages;
      }

      if (pageStatus) {
        pageStatus.textContent = `${currentPage} / ${totalPages}`;
      }
    };

    filters.forEach((filter) => {
      filter.addEventListener('click', () => {
        if (!(filter instanceof HTMLElement)) return;

        activeCategory = filter.dataset.category ?? '';
        activeSubcategory = filter.dataset.subcategory ?? '';
        currentPage = 1;

        updateFilterUrl();
        renderPosts();
      });
    });

    searchInput?.addEventListener('input', () => {
      if (!(searchInput instanceof HTMLInputElement)) return;

      searchQuery = normalizeSearchText(searchInput.value);
      currentPage = 1;
      renderPosts();
    });

    searchModeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (!(button instanceof HTMLElement)) return;

        searchMode = button.dataset.searchMode === 'body' ? 'body' : 'title';
        currentPage = 1;
        renderPosts();
      });
    });

    prevButton?.addEventListener('click', () => {
      currentPage -= 1;
      renderPosts();
    });

    nextButton?.addEventListener('click', () => {
      currentPage += 1;
      renderPosts();
    });

    renderPosts();
  </script>
</BlogLayout>
