---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="Projects" description="작은 도구와 장난감">
  <article class="projects-page">
    <header class="projects-header">
      <h1>Projects</h1>
      <p>작게 만든 도구와 장난감을 여기 모아둡니다.</p>
    </header>

    <section class="project-list" aria-label="Project list">
      <article class="project-entry">
        <div class="project-entry-main">
          <a href="/ucpc-scoreboard/">UCPC 동적 스코어보드</a>
          <p>
            UCPC archive의 Spotboard 데이터를 이용해 버추얼 컨테스트 중 원하는
            시점의 스코어보드를 보여줍니다.
          </p>
        </div>
        <span class="project-entry-meta">버추얼 컨테스트</span>
      </article>
    </section>
  </article>
</BlogLayout>

<style>
  .projects-page {
    max-width: 820px;
    margin: 0 auto;
  }

  .projects-header {
    margin-bottom: 34px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }

  .projects-header h1 {
    margin: 0 0 8px;
    font-size: 38px;
    line-height: 1.2;
    letter-spacing: 0;
  }

  .projects-header p {
    margin: 0;
    color: var(--muted);
  }

  .project-list {
    display: grid;
  }

  .project-entry {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: baseline;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
  }

  .project-entry:first-child {
    border-top: 1px solid var(--line);
  }

  .project-entry a {
    font-size: 22px;
    font-weight: 780;
    line-height: 1.35;
    letter-spacing: 0;
  }

  .project-entry a:hover {
    color: var(--link);
  }

  .project-entry p {
    max-width: 620px;
    margin: 8px 0 0;
    color: #4b5563;
  }

  .project-entry-meta {
    color: var(--muted);
    font-size: 13px;
    white-space: nowrap;
  }

  @media (max-width: 720px) {
    .projects-header h1 {
      font-size: 31px;
    }

    .project-entry {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
</style>
