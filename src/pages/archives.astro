---
import BlogLayout from '../layouts/BlogLayout.astro';
import { dateOnlyFormatter, formatCategory, getSortedPosts } from '../lib/posts';

const posts = getSortedPosts();

const postsByYear = posts.reduce<Record<string, typeof posts>>((groups, post) => {
  const year = post.publishedDate
    ? new Intl.DateTimeFormat('en', {
        timeZone: 'Asia/Seoul',
        year: 'numeric',
      }).format(post.publishedDate)
    : '날짜 없음';

  groups[year] ??= [];
  groups[year].push(post);
  return groups;
}, {});

const years = Object.keys(postsByYear).sort((a, b) => {
  if (a === '날짜 없음') return 1;
  if (b === '날짜 없음') return -1;
  return Number(b) - Number(a);
});

const toDomId = (value: string) => `archive-${value.replace(/\s+/gu, '-')}`;
---

<BlogLayout title="Archives" description="연도별 글 목록">
  <section class="hero">
    <h1>Archives</h1>
    <nav class="taxonomy-nav" aria-label="글 분류">
      <a href="/posts/">Posts</a>
      <a href="/categories/">Categories</a>
      <a href="/tags/">Tags</a>
      <a href="/feed.xml">RSS</a>
    </nav>
  </section>

  <section class="archive-list" aria-label="연도별 글 목록">
    {
      years.length === 0 ? (
        <p class="empty-state">아직 작성된 글이 없습니다.</p>
      ) : (
        years.map((year) => (
          <section class="archive-year" aria-labelledby={toDomId(year)}>
            <h2 id={toDomId(year)}>{year}</h2>
            <ol>
              {postsByYear[year].map((post) => (
                <li>
                  <time datetime={post.publishedDate?.toISOString() ?? ''}>
                    {post.publishedDate ? dateOnlyFormatter.format(post.publishedDate) : '날짜 없음'}
                  </time>
                  <a href={post.url}>{post.title}</a>
                  <span>{formatCategory(post.category, post.subcategory)}</span>
                </li>
              ))}
            </ol>
          </section>
        ))
      )
    }
  </section>
</BlogLayout>
