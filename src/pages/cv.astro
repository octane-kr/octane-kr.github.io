---
import BlogLayout from '../layouts/BlogLayout.astro';

const title = 'CV';
---

<BlogLayout title={title}>
  <article class="cv-page">
    <header class="cv-header">
      <p class="cv-kicker">CV</p>
      <h1>Taein Oh</h1>
      <p>
        Undergraduate student at KAIST studying mathematical sciences and
        computing.
      </p>
    </header>

    <section class="cv-section" aria-labelledby="education-heading">
      <h2 id="education-heading">Education</h2>

      <div class="cv-item">
        <div class="cv-item-main">
          <h3>Korea Advanced Institute of Science and Technology (KAIST)</h3>
          <p>B.S. student, Department of Mathematical Sciences</p>
          <p>Double major, School of Computing</p>
        </div>
        <p class="cv-meta">Class of 2023</p>
      </div>

      <div class="cv-item">
        <div class="cv-item-main">
          <h3>Seoul Science High School</h3>
          <p>32nd graduating class</p>
        </div>
      </div>
    </section>

    <section class="cv-section" aria-labelledby="teaching-heading">
      <h2 id="teaching-heading">Teaching &amp; Mentoring</h2>

      <div class="cv-item">
        <div class="cv-item-main">
          <h3>
            Teaching Assistant, CS.20002 Problem Solving Techniques
            (문제해결기법)
          </h3>
          <p>Korea Advanced Institute of Science and Technology (KAIST)</p>
        </div>
        <p class="cv-meta">Fall 2025</p>
      </div>

      <div class="cv-item">
        <div class="cv-item-main">
          <h3>Study Leader, RUN Intermediate Study</h3>
          <p>KAIST Algorithmic Problem Solving Club RUN</p>
        </div>
        <p class="cv-meta">Spring 2024, Fall 2024</p>
      </div>
    </section>

    <section class="cv-section" aria-labelledby="service-heading">
      <h2 id="service-heading">Leadership &amp; Service</h2>

      <div class="cv-item">
        <div class="cv-item-main">
          <h3>KAIST Algorithmic Problem Solving Club RUN</h3>
          <p>Served as Vice President.</p>
          <p>
            Reviewed problems and helped operate 2024 KAIST RUN Spring Contest and
            2024 KAIST 14th ICPC Mock Competition.
          </p>
          <p>
            Set one problem for the 2024 KAIST 14th ICPC Mock Competition:
            <a href="https://qoj.ac/contest/3633/problem/17880">G. Make RUN Great Again</a>.
          </p>
          <p>
            Coordinated communication with Jane Street and supported club
            outreach, event promotion, and community activities.
          </p>
        </div>
        <p class="cv-meta">2024</p>
      </div>
    </section>

    <section class="cv-section" aria-labelledby="cp-heading">
      <h2 id="cp-heading">Competitive Programming</h2>

      <div class="cv-subsection">
        <h3>Major Team Results</h3>
        <ul>
          <li>
            The 2025 ICPC Asia Ho Chi Minh City Regional Contest - 7th place,
            Rock kokiri paper, KAIST
          </li>
          <li>
            The ICPC Asia Pacific Championship 2026 - 47th place, Rock kokiri
            paper, KAIST
          </li>
        </ul>
      </div>

      <div class="cv-subsection">
        <h3>Selected Finalist Appearances</h3>
        <ul>
          <li>Samsung Collegiate Programming Challenge (SCPC), 2023-2025</li>
          <li>UCPC, 2023-2025</li>
          <li>ICPC Asia Seoul Regional Contest, 2024-2025</li>
          <li>2024 Hyundai Mobis Algorithm Competition</li>
        </ul>
      </div>
    </section>

    <section class="cv-section" aria-labelledby="awards-heading">
      <h2 id="awards-heading">Honors & Awards</h2>

      <div class="cv-item">
        <div class="cv-item-main">
          <h3>Mathematics Competition for University Students in Korea</h3>
          <p>Silver Medal, First Group (mathematics majors)</p>
        </div>
        <p class="cv-meta">2024</p>
      </div>

      <div class="cv-subsection">
        <h3>Selected Pre-University Awards</h3>
        <ul>
          <li>
            Korea Olympiad in Informatics (KOI), Silver Award, second round,
            2022
          </li>
          <li>
            Top Award, R&amp;E Research in Mathematics, Seoul Science High
            School, 2022
          </li>
          <li>
            Excellence Award, Graduation Research in Mathematics, Seoul Science
            High School, 2022
          </li>
          <li>2021 FKMO, Encouragement Award</li>
          <li>
            2019 Korean Mathematical Olympiad (KMO), high school division -
            Gold Award, first round; Silver Award, second round
          </li>
          <li>
            2018 Korean Mathematical Olympiad (KMO), middle school division -
            Silver Award, first round; Gold Award, second round
          </li>
        </ul>
      </div>
    </section>

    <section class="cv-section" aria-labelledby="interests-heading">
      <h2 id="interests-heading">Interests</h2>

      <p>
        Competitive programming; structural graph theory; algorithmic graph
        theory
      </p>
    </section>

    <section class="cv-section" aria-labelledby="profiles-heading">
      <h2 id="profiles-heading">Online Profiles</h2>

      <ul class="cv-profile-list" aria-label="online judge profiles">
        <li>
          <a href="https://codeforces.com/profile/octane">Codeforces</a>
          <span>max. International Master, 2368</span>
        </li>
        <li>
          <a href="https://atcoder.jp/users/octanec8h18">AtCoder</a>
          <span>highest rating 1651, 2 Kyu</span>
        </li>
        <li>
          <a href="https://solved.ac/profile/octane">solved.ac</a>
          <span>Ruby V, 2745; 1,336 Baekjoon problems solved</span>
        </li>
      </ul>
    </section>
  </article>
</BlogLayout>
