---
import BlogLayout from '../layouts/BlogLayout.astro';
import { formatCategory, getSortedPosts } from '../lib/posts';

const posts = getSortedPosts();

type CategoryGroup = {
  category: string;
  subcategories: Map<string, typeof posts>;
  posts: typeof posts;
};

const groups = new Map<string, CategoryGroup>();

for (const post of posts) {
  if (!groups.has(post.category)) {
    groups.set(post.category, {
      category: post.category,
      subcategories: new Map(),
      posts: [],
    });
  }

  const group = groups.get(post.category)!;
  group.posts.push(post);

  if (post.subcategory) {
    if (!group.subcategories.has(post.subcategory)) {
      group.subcategories.set(post.subcategory, []);
    }

    group.subcategories.get(post.subcategory)!.push(post);
  }
}

const categoryGroups = [...groups.values()].sort((a, b) =>
  a.category.localeCompare(b.category),
);

const toDomId = (value: string) =>
  `category-${value.toLowerCase().replace(/[^a-z0-9가-힣_-]+/gu, '-')}`;
---

<BlogLayout title="Categories" description="카테고리별 글 목록">
  <section class="hero">
    <h1>Categories</h1>
    <nav class="taxonomy-nav" aria-label="글 분류">
      <a href="/posts/">Posts</a>
      <a href="/archives/">Archives</a>
      <a href="/tags/">Tags</a>
    </nav>
  </section>

  <section class="taxonomy-list" aria-label="카테고리 목록">
    {
      categoryGroups.length === 0 ? (
        <p class="empty-state">아직 작성된 글이 없습니다.</p>
      ) : (
        categoryGroups.map((group) => (
          <section class="taxonomy-group" aria-labelledby={toDomId(group.category)}>
            <h2 id={toDomId(group.category)}>
              <a href={`/posts/?category=${encodeURIComponent(group.category)}`}>
                {group.category}
              </a>
              <span>{group.posts.length}</span>
            </h2>

            {group.subcategories.size > 0 && (
              <ul class="taxonomy-sublist">
                {[...group.subcategories.entries()]
                  .sort(([a], [b]) => a.localeCompare(b))
                  .map(([subcategory, subcategoryPosts]) => (
                    <li>
                      <a
                        href={`/posts/?category=${encodeURIComponent(group.category)}&subcategory=${encodeURIComponent(subcategory)}`}
                      >
                        {formatCategory(group.category, subcategory)}
                      </a>
                      <span>{subcategoryPosts.length}</span>
                    </li>
                  ))}
              </ul>
            )}

            <ol class="taxonomy-posts">
              {group.posts.slice(0, 5).map((post) => (
                <li>
                  <a href={post.url}>{post.title}</a>
                </li>
              ))}
            </ol>
          </section>
        ))
      )
    }
  </section>
</BlogLayout>
